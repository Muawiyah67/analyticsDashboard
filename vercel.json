{
  "version": 2,
  "buildCommand": "cd packages/shared && npm run build && cd ../api && npm run build",
  "functions": {
    "packages/api/dist/main.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/packages/api/dist/main.js"
    }
  ]
}